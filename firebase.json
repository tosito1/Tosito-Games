{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "hub",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/hub_main.html"
        }
      ]
    },
    {
      "target": "semantika",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/semantika.html"
        }
      ]
    }
  ]
}
